# ---------------------------------------------------------------------------
# StyleHub environment variables
# Copy this file to `.env` and fill in your Supabase connection strings.
# ---------------------------------------------------------------------------

# Supabase Postgres connection.
# In your Supabase project: Settings → Database → Connection string.
#  - DATABASE_URL: the "Connection pooling" (Transaction) URI, port 6543,
#    with ?pgbouncer=true appended. Used by the running app.
#  - DIRECT_URL:   the "Direct connection" URI, port 5432. Used for migrations.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:5432/postgres"

# Auth.js (NextAuth v5) secret — used to sign session JWTs.
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"
